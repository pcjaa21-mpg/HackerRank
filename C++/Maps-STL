#include <iostream>
#include <map>
#include <string>

using namespace std;

int main() 
{
    int q;
    cin >> q;
    
    map<string, int> marks_map;
    
    while (q--) 
    {
        int type;
        string name;
        cin >> type >> name;
        
        if (type == 1) 
        {
            int marks;
            cin >> marks;
             marks_map[name] += marks;
        } 
        else if (type == 2) 
        {
             marks_map.erase(name);
        } 
        else if (type == 3) 
        {
            cout << marks_map[name] << endl;
        }
    }
    
    return 0;
}
