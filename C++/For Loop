#include <iostream>
using namespace std;
int main() 
{
    int a, b;
    cin >> a >> b;
    const char* words[] = {"", "one", "two", "three", "four", "five", "six", "seven", "eight", "nine"};
    for (int i = a; i <= b; i++) 
    {
        if (i <= 9) 
            cout << words[i] << endl;
        else 
            cout << (i % 2 == 0 ? "even" : "odd") << endl;
    }
    return 0;
}
