#include <iostream>
#include <vector>
using namespace std;
int main() 
{
    int n, q, k, i, j;
    cin >> n >> q;
    vector<int> a[n]; 
    for (i = 0; i < n; i++) 
    {
        cin >> k;
        a[i].resize(k);
        for (j = 0; j < k; j++) cin >> a[i][j];
    }

    while (q--) 
    {
        cin >> i >> j;
        cout << a[i][j] << endl;
    }
    return 0;
}
